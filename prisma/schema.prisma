generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String           @id @default(cuid())
  name              String
  email             String           @unique
  password          String?
  baseResume        String?          @db.Text
  homeLocation      String?
  lineUserId        String?          @unique
  lineLinkCode      String?
  tokenUsageTotal   Int              @default(0)
  tokenUsageWindow  Int              @default(0)
  tokenLimit        Int              @default(50000)
  scrapeUsageTotal  Int              @default(0)
  scrapeUsageWindow Int              @default(0)
  scrapeLimit       Int              @default(10)
  nextQuotaReset    DateTime         @default(now())
  createdAt         DateTime         @default(now())
  applications      JobApplication[]
}

model JobApplication {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company        String
  role           String
  status         Status    @default(WISHLIST)
  url            String?
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String    @default("THB")
  salaryPeriod   String    @default("MONTHLY")
  location       String?
  workMode       String    @default("ONSITE")
  jobDescription String?   @db.Text
  notes          String?
  source         String?
  appliedAt      DateTime?
  interviewDate  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

enum Status {
  WISHLIST
  APPLIED
  INTERVIEWING
  OFFERED
  REJECTED
  GHOSTED
}
